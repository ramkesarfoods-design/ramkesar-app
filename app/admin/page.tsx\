"use client";

import { useEffect, useState } from "react";
import { auth, db } from "@/firebase/config";
import { onAuthStateChanged, signInWithEmailAndPassword, signOut } from "firebase/auth";
import { collection, query, orderBy, onSnapshot, doc, updateDoc } from "firebase/firestore";
import { 
  ShoppingBag, Truck, CheckCircle2, Clock, MapPin, 
  User, Bike, DollarSign, Lock, ShieldCheck, LogOut 
} from "lucide-react";

export default function AdminDashboard() {
  const [user, setUser] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [orders, setOrders] = useState<any[]>([]);
  
  // Login States
  const [email, setEmail] = useState("");
  const [pass, setPass] = useState("");
  const [loginError, setLoginError] = useState("");

  useEffect(() => {
    // 1. Check Auth State
    const unsubAuth = onAuthStateChanged(auth, (currentUser) => {
      setUser(currentUser);
      setLoading(false);
    });

    // 2. Fetch Orders if User exists
    let unsubOrders: any;
    if (user) {
      const q = query(collection(db, "orders"), orderBy("createdAt", "desc"));
      unsubOrders = onSnapshot(q, (snap) => {
        setOrders(snap.docs.map(d => ({ id: d.id, ...d.data() })));
      });
    }

    return () => {
      unsubAuth();
      if (unsubOrders) unsubOrders();
    };
  }, [user]);

  const handleLogin = async (e: any) => {
    e.preventDefault();
    setLoginError("");
    try {
      await signInWithEmailAndPassword(auth, email, pass);
    } catch (err) {
      setLoginError("Invalid Admin Credentials");
    }
  };

  const updateStatus = async (id: string, s: string) => {
    await updateDoc(doc(db, "orders", id), { status: s });
  };

  if (loading) return <div className="h-screen flex items-center justify-center bg-black text-white font-black italic uppercase">Loading...</div>;

  // 🚪 IF NOT LOGGED IN: SHOW LOGIN FORM
  if (!user) {
    return (
      <div className="min-h-screen bg-black flex items-center justify-center p-6">
        <div className="w-full max-w-sm bg-[#0A0A0A] p-10 rounded-[3rem] border border-white/5 shadow-2xl">
          <div className="text-center mb-8">
            <div className="w-16 h-16 bg-red-600 rounded-2xl flex items-center justify-center text-white mb-4 mx-auto rotate-3"><Lock size={28}/></div>
            <h1 className="text-white font-black italic text-2xl uppercase tracking-tighter">Admin Login</h1>
          </div>
          <form onSubmit={handleLogin} className="space-y-4">
            {loginError && <p className="text-red-500 text-[10px] font-black uppercase text-center">{loginError}</p>}
            <input type="email" placeholder="ADMIN EMAIL" className="w-full bg-white/5 border border-white/10 p-5 rounded-2xl text-white font-bold text-xs outline-none" onChange={e => setEmail(e.target.value)} required />
            <input type="password" placeholder="PASSWORD" className="w-full bg-white/5 border border-white/10 p-5 rounded-2xl text-white font-bold text-xs outline-none" onChange={e => setPass(e.target.value)} required />
            <button className="w-full bg-red-600 text-white p-5 rounded-2xl font-black text-xs uppercase italic tracking-widest active:scale-95 transition-all">Enter Dashboard</button>
          </form>
        </div>
      </div>
    );
  }

  // 👑 IF LOGGED IN: SHOW ADMIN DASHBOARD
  return (
    <div className="min-h-screen bg-[#F8F9FA]">
      <nav className="bg-black text-white p-5 sticky top-0 z-50 flex justify-between items-center shadow-xl">
        <div className="flex items-center gap-2">
          <div className="bg-red-600 px-2 py-1 rounded font-black italic">RK</div>
          <h1 className="font-black italic uppercase tracking-tighter">Admin Panel</h1>
        </div>
        <button onClick={() => signOut(auth)} className="text-gray-400 hover:text-white transition-colors"><LogOut size={20}/></button>
      </nav>

      <div className="max-w-5xl mx-auto p-4 lg:p-8">
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {orders.map((order) => (
            <div key={order.id} className="bg-white rounded-[2.5rem] p-6 border border-gray-100 shadow-sm">
              <div className="flex justify-between mb-4">
                <span className="text-[10px] font-black text-gray-400 uppercase italic">ID: #{order.id.slice(-6)}</span>
                <span className="bg-orange-50 text-orange-600 px-3 py-1 rounded-full text-[9px] font-black uppercase italic">{order.status}</span>
              </div>
              <h2 className="text-2xl font-black italic text-gray-900 mb-4">₹{order.totalAmount}</h2>
              <div className="bg-gray-50 p-4 rounded-2xl mb-4 text-[11px] font-bold text-gray-600">
                {order.items?.map((it: any, i: number) => <div key={i}>{it.qty}x {it.name}</div>)}
              </div>
              <div className="flex items-start gap-2 mb-6 text-[10px] font-bold text-gray-400 italic">
                <MapPin size={12} className="text-red-500 shrink-0"/> {order.address}
              </div>
              <div className="grid grid-cols-2 gap-2">
                <button onClick={() => updateStatus(order.id, "On the Way")} className="bg-blue-600 text-white py-3 rounded-xl font-black text-[10px] uppercase italic">Send Rider</button>
                <button onClick={() => updateStatus(order.id, "Delivered")} className="bg-green-600 text-white py-3 rounded-xl font-black text-[10px] uppercase italic">Delivered</button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
